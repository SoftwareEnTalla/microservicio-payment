APP_NAME=PaymentApp
STAGE=DEV
PORT=3005
LANDING_APP=http://localhost:3001
ADMIN_APP=http://localhost:3002
JWT_SECRET=mysecretkey

# Base de datos (usar hostname del servicio de Compose)
DB_TYPE=postgres
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=payment-service
LANG=es

# APIs y autenticación
API_KEY=myapikey
SA_EMAIL=softwarentalla@gmail.com
SA_PWD=admin123

# Codetrace REST endpoint (fallback si Kafka no está disponible).
# IMPORTANTE: debe apuntar al codetrace-service, NO al propio microservicio.
# Para Docker usar el hostname del servicio (codetrace-service); para host usar localhost:3002.
LOG_API_BASE_URL=http://codetrace-service:3002/api
LOG_API_SCOPE=codetraces
LOG_API_CREATE_ACTION=command
# Token Bearer opcional para autenticarse contra el guard de codetrace
LOG_API_AUTH_TOKEN=
LOG_API_STRICT_SSL=false
KEY_LOG=http

# Redis (infra data-center)
REDIS_HOST=data-center-redis
REDIS_PORT=6379
REDIS_TTL=3600

# Cloudinary
CLD_NAME=cloudinary_name
CLD_FOLDER=myfolder
CLD_API_KEY=cloudinary_key
CLD_API_SECRET=cloudinary_secret

# Swagger auth
SWAGGER_USER=admin
SWAGGER_PWD=admin123

# Mail
MAIL_HOST_API=mailapi.example.com
MAIL_HOST=smtp.example.com
MAIL_USER=softwarentalla@gmail.com
MAIL_PORT_SSL=465
MAIL_PASS=mailpassword
MAIL_API_USER_ID=mailapiuserid
MAIL_API_SECRET=mailapisecret

# Entorno y logging
NODE_ENV=development
DB_LOGGING=true
LOG_LEVEL=info

# LOG_EXECUTION_TIME activa el decorador @LogExecutionTime y habilita el envío
# de trazas al codetrace-service. REQUIERE que codetrace-service esté corriendo.
# Si codetrace NO está disponible, poner LOG_EXECUTION_TIME=false para evitar
# overhead y mensajes huérfanos.
LOG_EXECUTION_TIME=true

# LOG_READY debe ser "true" para que @LogExecutionTime envuelva los métodos
# (de lo contrario el decorator es no-op silencioso, sin trazas).
LOG_READY=true

# Modo de entrega de trazas al codetrace-service:
#   KAFKA (default) = productor Kafka al tópico codetrace-execution-trace.
#                     Si Kafka no responde, hace fallback automático a REST
#                     (POST a LOG_API_BASE_URL/codetraces/command).
#   EVENT           = alias de KAFKA (compatibilidad hacia atrás).
#   REST            = solo HTTP POST a LOG_API_BASE_URL (sin Kafka).
LOG_DELIVERY_MODE=KAFKA
LOG_KAFKA_TOPIC=codetrace-execution-trace

# Event Sourcing
EVENT_SOURCING_ENABLED=true
KAFKA_ENABLED=true
EVENT_STORE_ENABLED=false

# Kafka
KAFKA_BROKERS=kafka:9092
KAFKA_GROUP_ID=nestjs-group
KAFKA_CLIENT_ID=nestjs-client
# Silenciar advertencia de particionador por defecto
KAFKAJS_NO_PARTITIONER_WARNING=1

# Event Store
EVENT_STORE_URL=esdb://localhost:2113?tls=false
EVENT_STORE_STREAM_PREFIX=microservice-

# Debug de Node
NODE_DEBUG=net
NODE_TLS_REJECT_UNAUTHORIZED=0

## Control de conexión a base de datos (infra data-center)
INCLUDING_DATA_BASE_SYSTEM=true

## Habilitar GraphQL (opcional)
GRAPHQL_ENABLED=false

# Ollama LLM Configuration
OLLAMA_BASE_URL=http://data-center-ollama:11434
OLLAMA_MODEL=llama2
OLLAMA_TEMPERATURE=0.7
OLLAMA_TOP_P=0.9
OLLAMA_TIMEOUT=300
OLLAMA_CONTEXT_STRATEGY=auto
OLLAMA_MAX_PROMPT_CHARS=24000
OLLAMA_CONTEXT_CHUNK_CHARS=12000
OLLAMA_BRIEFING_MAX_CHARS=8000

# User History & DSL Generation
USER_HISTORIES_DIR=user-histories
DSL_SCHEMAS_DIR=models
DSL_OUTPUT_DIR=models
DSL_VALIDATION_ENABLED=true

